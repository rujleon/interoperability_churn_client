cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]
*.so
.Python

# Virtual environments
.venv/
venv/
env/

# Binary files (critical for Hugging Face)
*.pkl
*.h5
*.joblib
*.db
*.sqlite

# Logs and data
*.log
data/

# IDE
.vscode/
.idea/

# Secrets
.env
.env.local

# OS
.DS_Store
EOF

git add .gitignore
git commit -m "chore: comprehensive .gitignore for HF Spaces"